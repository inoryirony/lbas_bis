{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "index.js",
    "src/**/*.js",
    "test/**/*.js"
  ]
}
